# Supabase (mesmo projeto do bot Telegram legado — nunca quebrar compatibilidade)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Sessão do painel admin (login próprio, tabela ADMINISTRADORES) — string aleatória longa
ADMIN_SESSION_SECRET=

# Efí Bank (Pix + cartão) — sdk-node-apis-efi
EFI_CLIENT_ID=
EFI_CLIENT_SECRET=
EFI_CHAVE_PIX=
# Certificado .p12/.pem da API Pix da Efí, em base64 (não é um caminho de arquivo)
EFI_CERTIFICADO_BASE64=
# "false" só em produção — qualquer outro valor (ou ausente) usa o sandbox da Efí
EFI_SANDBOX=true

# Tokenização de cartão no navegador (payment-token-efi) — painel Efí em
# "API > Introdução > Identificador de Conta". Diferente do CLIENT_ID/SECRET
# acima; esse aqui é público (usado no client) e não expõe nada sensível.
NEXT_PUBLIC_EFI_PAYEE_CODE=
# "false" só em produção — precisa acompanhar o valor de EFI_SANDBOX
NEXT_PUBLIC_EFI_SANDBOX=true

# Bunny.net (CDN de vídeo HLS/DASH)
BUNNY_CDN_URL=

# Username do bot do Telegram (sem @), usado no link de vinculação de conta
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=
